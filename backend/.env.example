QWEN_API_KEY=ta_cle_ici

# SMTP (optionnel) - si absent ou incomplet, l'envoi d'email est simule (log console)
# au lieu d'un envoi reel. Exemple avec Gmail : utilise un mot de passe d'application,
# pas ton mot de passe de compte. Ou utilise un service de test type Mailtrap.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Destinataire par defaut utilise par Orion quand aucune adresse reelle n'a ete
# mentionnee dans la conversation.
ACTION_TEST_RECIPIENT=test@exemple.com
