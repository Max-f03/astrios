QWEN_API_KEY=ta_cle_ici

# Fuseau horaire de l'utilisateur (nom IANA), utilise pour interpreter les dates
# et heures relatives ("demain", "13h") et pour creer les evenements calendrier
# (Google Calendar API + .ics) a la bonne heure locale.
APP_TIMEZONE=Africa/Porto-Novo

# Mode expediteur serveur : compte Gmail dedie a la demo, utilise via SMTP quand
# aucun compte Google utilisateur (OAuth) n'est connecte. Permet a n'importe quel
# visiteur de tester l'execution reelle sans passer par OAuth (app en mode "Test").
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=orionastrios@gmail.com
SMTP_APP_PASSWORD=REMPLACER_MOI
SENDER_DISPLAY_NAME=Orion — Astrios
